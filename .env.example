# =============================================================================
# DISTRIBUTED AI NETWORK - Environment Configuration
# Copy this file to .env and adjust values for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=ai
POSTGRES_PASSWORD=ai_secure_password
POSTGRES_DB=ainetwork

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP=localhost:29092
KAFKA_CONSUMER_GROUP=ai-network

# Topics
KAFKA_TOPIC_TASKS=ai.tasks.v2
KAFKA_TOPIC_RESULTS=ai.results.v2
KAFKA_TOPIC_EVENTS=ai.events.v1
KAFKA_TOPIC_AUDIT=ai.audit.v1

# -----------------------------------------------------------------------------
# Main Server Configuration
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8020
DEBUG=false
LOG_LEVEL=INFO

# Worker task timeout (seconds)
WORKER_TASK_TIMEOUT=300

# Validation rewards
VALIDATION_MATCH_REWARD_A=0.05
VALIDATION_MATCH_REWARD_B=0.02
VALIDATION_MISMATCH_PENALTY=0.1
VALIDATION_MISMATCH_BONUS_B=0.01

# Reputation settings
REPUTATION_INCREASE_ON_SUCCESS=0.01
REPUTATION_DECREASE_ON_FAILURE=0.1
REPUTATION_VALIDATOR_BONUS=0.005

# Golden tasks (honeypots)
GOLDEN_TASK_RATIO=0.1
GOLDEN_TASK_PENALTY_MULTIPLIER=2.0

# Task type rewards
REWARD_TEXT=0.05
REWARD_REVERSE=0.10
REWARD_MATH=0.15
REWARD_LLM=0.50
REWARD_HEAVY=1.00

# -----------------------------------------------------------------------------
# API Gateway Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
MAX_UPLOAD_SIZE=104857600
DEFAULT_CHUNK_SIZE=50

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Router Configuration
# -----------------------------------------------------------------------------
GPU_THRESHOLD=100
CPU_TOPIC=ai.tasks.cpu
GPU_TOPIC=ai.tasks.gpu

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT settings (for future auth implementation)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Tracing
TRACING_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_GOLDEN_TASKS=true
FEATURE_REPUTATION_DECAY=true
FEATURE_COLLUSION_DETECTION=true
FEATURE_WEBSOCKET_UPDATES=true

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
# Set to true to enable hot reload and debug endpoints
DEV_MODE=false
